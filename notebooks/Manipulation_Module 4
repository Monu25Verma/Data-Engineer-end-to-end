    "#Sales Performance Tracker: Create a class called SalesRep that stores a representative’s name and a list of their sales amounts.\n",
    "\n",
    "#Include methods to add sales amounts, calculate average sales, and determine if they hit a target (parameter).\n",
    "\n",
    "# SalesRep Class\n",
    "\n",
    "class SalesRep:\n",
    "\n",
    "    def __init__(self, name, sales=None):\n",
    "        self.name = name\n",
    "        self.sales = sales if sales else []\n",
    "\n",
    "    # Add a new sales amount\n",
    "    def add_sale(self, amount):\n",
    "        self.sales.append(amount)\n",
    "\n",
    "    # Calculate average sales\n",
    "    def average_sales(self):\n",
    "        if len(self.sales) == 0:\n",
    "            return 0\n",
    "        return sum(self.sales) / len(self.sales)\n",
    "\n",
    "    # Check if average sales hit target\n",
    "    def hit_target(self, target):\n",
    "        return self.average_sales() >= target\n",
    "\n",
    "    # Display sales rep details\n",
    "    def display_info(self):\n",
    "        print(f\"\\nSales Rep: {self.name}\")\n",
    "        print(f\"Sales Amounts: {self.sales}\")\n",
    "        print(f\"Average Sales: {self.average_sales():.2f}\")\n",
    "\n",
    "\n",
    "# Sample data\n",
    "sales_data = {\n",
    "    \"Alice Johnson\": [15000, 18000, 22000, 16000, 19000, 21000],\n",
    "    \"Bob Smith\": [12000, 14000, 11000, 13000, 15000, 16000],\n",
    "    \"Carol Davis\": [25000, 28000, 30000, 27000, 32000, 29000]\n",
    "}\n",
    "\n",
    "# Create objects\n",
    "sales_reps = []\n",
    "\n",
    "for name, sales in sales_data.items():\n",
    "    rep = SalesRep(name, sales)\n",
    "    sales_reps.append(rep)\n",
    "\n",
    "# Add a new sale\n",
    "sales_reps[0].add_sale(23000)\n",
    "\n",
    "# Set target\n",
    "target = 20000\n",
    "\n",
    "# Display results\n",
    "for rep in sales_reps:\n",
    "    rep.display_info()\n",
    "\n",
    "    if rep.hit_target(target):\n",
    "        print(\"Target Achieved\")\n",
    "    else:\n",
    "        print(\"Target Not Achieved\")"
   ]
